---
import PageLayout from '~/layouts/PageLayout.astro';
import ContactoSection from '~/components/landing/ContactoSection.astro';
import PersonalizaSection from '~/components/landing/PersonalizaSection.astro';

// Render
const renderModules = import.meta.glob('../../../content/promociones/alameda-de-osuna-iii/renders/**', {
  eager: true,
  query: '?url',
  import: 'default',
});
const renderUrls = Object.values(renderModules) as string[];
const heroRender = renderUrls[0] ?? null;

// Photos
const photoModules = import.meta.glob('../../../content/promociones/alameda-de-osuna-iii/photos/**', {
  eager: true,
  query: '?url',
  import: 'default',
});
const photoUrls = (Object.values(photoModules) as string[]).sort();
const heroPhoto = heroRender ?? photoUrls[0] ?? null;
const galleryPhotos = heroRender ? photoUrls : photoUrls.slice(1);

// Root-level PDFs (Memoria)
const rootPdfs = import.meta.glob('../../../content/promociones/alameda-de-osuna-iii/*.pdf', {
  eager: true,
  query: '?url',
  import: 'default',
});
const memoriaUrl = Object.entries(rootPdfs).find(([k]) => k.includes('MEMORIA'))?.[1] as string;

// Avances de obra PDFs
const avancePdfs = import.meta.glob('../../../content/promociones/alameda-de-osuna-iii/avance-obra/*.pdf', {
  eager: true,
  query: '?url',
  import: 'default',
});
const monthOrder: Record<string, number> = {
  Enero: 1, Febrero: 2, Marzo: 3, Abril: 4, Mayo: 5, Junio: 6,
  Julio: 7, Agosto: 8, Septiembre: 9, Octubre: 10, Noviembre: 11, Diciembre: 12,
};
const avances = Object.entries(avancePdfs)
  .map(([path, url]) => {
    const filename = path.split('/').pop()!;
    const match = filename.match(/-([A-Za-z]+)-(\d{4})\.pdf$/);
    const month = match?.[1] ?? '';
    const year = match?.[2] ?? '';
    const label = match ? `${month} ${year}` : filename.replace('.pdf', '');
    const sortKey = match ? `${year}-${String(monthOrder[month] ?? 0).padStart(2, '0')}` : filename;
    return { url: url as string, label, sortKey };
  })
  .sort((a, b) => a.sortKey.localeCompare(b.sortKey));

const urbanizacionItems = [
  {
    title: 'Conserjería',
    desc: 'Dos garitas de conserjería con sistema perimetral de seguridad.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 7a4 4 0 1 0 8 0a4 4 0 0 0 -8 0" /><path d="M6 21v-2a4 4 0 0 1 4 -4h4a4 4 0 0 1 4 4v2" /></svg>`,
  },
  {
