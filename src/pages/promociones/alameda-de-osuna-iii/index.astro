---

<PageLayout
  metadata={{
    title: 'Alameda de Osuna III — Clement',
    description:
      'CLEMENT Alameda de Osuna III: 66 viviendas llave en mano de 1, 2, 3 y 4 dormitorios en urbanización privada con piscina, pádel y zonas ajardinadas en La Alameda de Osuna, Madrid.',
  }}
>
  <!-- ═══════════════════════════════════════════════════════ HERO ══ -->
  <section class="relative h-screen overflow-hidden">
    {
      heroPhoto && (
        <img
          src={heroPhoto}
          alt="Alameda de Osuna III — vista exterior"
          class="absolute inset-0 w-full h-full object-cover"
        />
      )
    }
    <div class="absolute inset-0 bg-linear-to-t from-slate-900/80 via-slate-900/30 to-slate-900/20"></div>
    <div class="relative h-full flex flex-col justify-end max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
      <a
        href="/#promociones"
        class="hero-fade inline-flex items-center gap-2 text-white/70 hover:text-white text-sm font-light mb-6 transition-colors w-fit"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Volver a promociones
      </a>
      <div class="hero-fade inline-block mb-4" style="animation-delay: 0.1s">
        <span class="text-white/60 uppercase tracking-[0.3em] text-xs font-light">Entregado · Madrid</span>
      </div>
      <h1 class="hero-fade text-5xl md:text-7xl font-serif font-bold text-white mb-4" style="animation-delay: 0.2s">
        Alameda de Osuna III
      </h1>
      <p class="hero-fade text-white/80 text-lg font-light max-w-2xl" style="animation-delay: 0.3s">
        66 viviendas llave en mano de 1, 2, 3 y 4 dormitorios con dos plazas de garaje incluidas
      </p>
    </div>
    <a
      href="#descripcion"
      class="hero-fade absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center text-white/60 hover:text-white transition-colors group"
      style="animation-delay: 0.5s"
    >
      <span class="text-xs tracking-[0.25em] uppercase mb-3">Descubre</span>
      <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
      </svg>
    </a>
  </section>

  <!-- ══════════════════════════════════════════════ DESCRIPCIÓN ══ -->
  <section id="descripcion" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-reveal">
          <div class="inline-block mb-6">
            <div class="h-px w-12 bg-brand-600 inline-block"></div>
            <span class="mx-4 text-slate-500 uppercase tracking-[0.3em] text-xs font-light">La Promoción</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-serif font-bold text-slate-900 mb-8">
            Llave en mano, sin sorpresas
          </h2>
          <p class="text-slate-600 leading-relaxed font-light text-lg mb-6">
            CLEMENT Alameda de Osuna III es una promoción de 66 viviendas llave en mano de 1, 2, 3 y 4 dormitorios
            distribuidas en 5 portales. Todas las viviendas disponen de terraza y dos plazas de garaje incluidas en el
            precio.
          </p>
          <p class="text-slate-600 leading-relaxed font-light text-lg">
            Situada en la C/ San Severo (28042 Madrid), la urbanización cuenta con piscina, jardines, pista de pádel,
            zona infantil, sala polivalente y conserjería, en un entorno residencial privilegiado.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="scroll-reveal-item bg-slate-50 p-8 border border-slate-100 text-center">
            <div class="text-4xl font-serif font-bold text-slate-900 mb-2">66</div>
            <div class="text-slate-500 text-sm uppercase tracking-wider font-light">Viviendas</div>
          </div>
          <div class="scroll-reveal-item bg-slate-50 p-8 border border-slate-100 text-center">
            <div class="text-4xl font-serif font-bold text-slate-900 mb-2">5</div>
            <div class="text-slate-500 text-sm uppercase tracking-wider font-light">Portales</div>
          </div>
          <div class="scroll-reveal-item bg-slate-50 p-8 border border-slate-100 text-center">
            <div class="text-4xl font-serif font-bold text-slate-900 mb-2">1–4</div>
            <div class="text-slate-500 text-sm uppercase tracking-wider font-light">Dormitorios</div>
          </div>
          <div class="scroll-reveal-item bg-brand-600 p-8 text-center">
            <div class="text-4xl font-serif font-bold text-white mb-2">100%</div>
            <div class="text-white/80 text-sm uppercase tracking-wider font-light">Vendido</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ PHOTO GALLERY ══ -->
  {
    galleryPhotos.length > 0 && (
      <section class="py-24 bg-slate-900">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="scroll-reveal text-center mb-16">
            <div class="inline-block mb-4">
              <div class="h-px w-12 bg-slate-500 inline-block" />
              <span class="mx-4 text-slate-400 uppercase tracking-[0.3em] text-xs font-light">Galería</span>
              <div class="h-px w-12 bg-slate-500 inline-block" />
            </div>
            <h2 class="text-4xl md:text-5xl font-serif font-bold text-white">La Promoción Terminada</h2>
            <p class="text-slate-400 font-light mt-4 max-w-xl mx-auto">
              Fotografías reales del resultado final de la promoción
            </p>
