---
import PageLayout from '~/layouts/PageLayout.astro';
import ContactoSection from '~/components/landing/ContactoSection.astro';

const urbanizacionItems = [
  {
    title: 'Piscina',
    desc: 'Con iluminación interior LED y sistema de depuración salina.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M2 20a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1a2.4 2.4 0 0 1 2 -1a2.4 2.4 0 0 1 2 1a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1a2.4 2.4 0 0 1 2 -1a2.4 2.4 0 0 1 2 1a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1" /><path d="M2 16a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1a2.4 2.4 0 0 1 2 -1a2.4 2.4 0 0 1 2 1a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1a2.4 2.4 0 0 1 2 -1a2.4 2.4 0 0 1 2 1a2.4 2.4 0 0 0 2 1a2.4 2.4 0 0 0 2 -1" /><path d="M15 12v-7.5a1.5 1.5 0 0 1 3 0" /><path d="M9 12v-7.5a1.5 1.5 0 0 0 -3 0" /><path d="M15 5l-6 0" /><path d="M9 10l6 0" /></svg>`,
  },
  {
    title: 'Zonas Comunes',
    desc: 'Jardines y zonas de descanso con iluminación exterior.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 21c.5 -4.5 2.5 -8 7 -10" /><path d="M9 18c6.218 0 10.5 -3.288 11 -12v-2h-4.014c-9 0 -11.986 4 -12 9c0 1 0 3 2 5h3l.014 0" /></svg>`,
  },
  {
    title: 'Garaje',
    desc: 'Plaza de garaje incluida con cada vivienda.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 20a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M15 20a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M5 20h-2v-6l2 -5h9l4 5h1a2 2 0 0 1 2 2v4h-2m-4 0h-6m-6 -6h15m-6 0v-5" /><path d="M3 6l9 -4l9 4" /></svg>`,
  },
  {
    title: 'Terraza',
    desc: 'Todas las viviendas disponen de terraza propia.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21h18" /><path d="M4 21v-15l8 -3l8 3v15" /><path d="M14 21v-8h-4v8" /><path d="M4 10.5h16" /></svg>`,
  },
  {
    title: 'Energía Solar',
    desc: 'Supone un gran ahorro en agua caliente sanitaria.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M8 2a4 4 0 1 0 8 0" /><path d="M4 3h1" /><path d="M19 3h1" /><path d="M12 9v1" /><path d="M17.2 7.2l.707 .707" /><path d="M6.8 7.2l-.7 .7" /><path d="M4.28 21h15.44a1 1 0 0 0 .97 -1.243l-1.5 -6a1 1 0 0 0 -.97 -.757h-12.44a1 1 0 0 0 -.97 .757l-1.5 6a1 1 0 0 0 .97 1.243" /><path d="M4 17h16" /><path d="M10 13l-1 8" /><path d="M14 13l1 8" /></svg>`,
  },
  {
    title: 'Dormitorios',
    desc: 'Viviendas de 2 o 4 dormitorios según tipología.',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 9a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M22 17v-3h-20" /><path d="M2 8v9" /><path d="M12 14h10v-2a3 3 0 0 0 -3 -3h-7v5" /></svg>`,
  },
];
---

<PageLayout
  metadata={{
    title: 'Alameda de Osuna V — Clement',
    description:
      'CLEMENT Alameda de Osuna V: 48 viviendas de 2 y 4 dormitorios con terraza, plaza de garaje y piscina en La Alameda de Osuna, Madrid. Promoción 100% vendida.',
  }}
>
  <!-- ═══════════════════════════════════════════════════════ HERO ══ -->
  <section class="relative h-screen overflow-hidden bg-slate-900">
    <div class="absolute inset-0 bg-linear-to-br from-slate-900 via-slate-800 to-slate-900"></div>
    <div class="absolute inset-0 opacity-5">
      <div
        class="absolute inset-0"
        style="background-image: repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,0.03) 60px, rgba(255,255,255,0.03) 61px), repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(255,255,255,0.03) 60px, rgba(255,255,255,0.03) 61px);"
      >
      </div>
    </div>
    <div class="relative h-full flex flex-col justify-end max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-32">
      <a
        href="/#promociones"
        class="hero-fade inline-flex items-center gap-2 text-white/70 hover:text-white text-sm font-light mb-6 transition-colors w-fit"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        Volver a promociones
      </a>
      <div class="hero-fade inline-block mb-4" style="animation-delay: 0.1s">
        <span class="text-white/60 uppercase tracking-[0.3em] text-xs font-light">Entregado · Madrid</span>
      </div>
      <h1 class="hero-fade text-5xl md:text-7xl font-serif font-bold text-white mb-4" style="animation-delay: 0.2s">
        Alameda de Osuna V
      </h1>
      <p class="hero-fade text-white/80 text-lg font-light max-w-2xl" style="animation-delay: 0.3s">
        48 viviendas de 2 y 4 dormitorios con terraza, plaza de garaje y piscina
      </p>
    </div>
    <a
      href="#descripcion"
      class="hero-fade absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center text-white/60 hover:text-white transition-colors group"
      style="animation-delay: 0.5s"
    >
      <span class="text-xs tracking-[0.25em] uppercase mb-3">Descubre</span>
      <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
      </svg>
    </a>
  </section>

  <!-- ══════════════════════════════════════════════ DESCRIPCIÓN ══ -->
  <section id="descripcion" class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="scroll-reveal">
          <div class="inline-block mb-6">
            <div class="h-px w-12 bg-brand-600 inline-block"></div>
            <span class="mx-4 text-slate-500 uppercase tracking-[0.3em] text-xs font-light">La Promoción</span>
          </div>
          <h2 class="text-4xl md:text-5xl font-serif font-bold text-slate-900 mb-8">
            Promoción 100% vendida
          </h2>
          <p class="text-slate-600 leading-relaxed font-light text-lg mb-6">
            CLEMENT Alameda de Osuna V se distribuye en dos portales de cinco plantas más ático en cada uno de ellos.
            La promoción está compuesta por 48 viviendas de 2 y 4 dormitorios con terraza, plaza de garaje, piscina y
            zonas comunes.
          </p>
          <div class="bg-slate-50 border border-slate-200 p-6">
            <p class="text-slate-700 font-medium mb-2">Esta promoción se encuentra totalmente comercializada.</p>
            <p class="text-slate-500 font-light text-sm">
              Si desea recibir información sobre futuras promociones, rellene el formulario al final de esta página y
              le avisaremos cuando haya disponibilidad.
            </p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="scroll-reveal-item bg-slate-50 p-8 border border-slate-100 text-center">
            <div class="text-4xl font-serif font-bold text-slate-900 mb-2">48</div>
            <div class="text-slate-500 text-sm uppercase tracking-wider font-light">Viviendas</div>
          </div>
          <div class="scroll-reveal-item bg-slate-50 p-8 border border-slate-100 text-center">
            <div class="text-4xl font-serif font-bold text-slate-900 mb-2">2</div>
            <div class="text-slate-500 text-sm uppercase tracking-wider font-light">Portales</div>
          </div>
          <div class="scroll-reveal-item bg-slate-50 p-8 border border-slate-100 text-center">
            <div class="text-4xl font-serif font-bold text-slate-900 mb-2">2 y 4</div>
            <div class="text-slate-500 text-sm uppercase tracking-wider font-light">Dormitorios</div>
          </div>
          <div class="scroll-reveal-item bg-brand-600 p-8 text-center">
            <div class="text-4xl font-serif font-bold text-white mb-2">100%</div>
            <div class="text-white/80 text-sm uppercase tracking-wider font-light">Vendido</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════ UBICACIÓN ══ -->
  <section class="py-24 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="scroll-reveal text-center mb-16">
        <div class="inline-block mb-4">
          <div class="h-px w-12 bg-slate-600 inline-block"></div>
          <span class="mx-4 text-slate-500 uppercase tracking-[0.3em] text-xs font-light">Ubicación</span>
          <div class="h-px w-12 bg-slate-600 inline-block"></div>
        </div>
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-slate-900 mb-6">La Alameda de Osuna</h2>
        <p class="text-slate-600 font-light max-w-3xl mx-auto leading-relaxed text-lg">
          Situada en la C/ Tomillar (28042 Madrid), un barrio consolidado, residencial y tranquilo, dotado de
          comercios de todo tipo. A 10 minutos del centro de Madrid por la A-2, M-22, M-40 y M-11.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="scroll-reveal-item bg-white p-8 border border-slate-200">
          <div class="w-10 h-10 bg-brand-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Transporte público</h3>
          <p class="text-slate-600 font-light text-sm leading-relaxed">
            Metro Línea 5 (Alameda de Osuna) · Autobuses 105, 112, 115, 151 y N4
          </p>
        </div>
        <div class="scroll-reveal-item bg-white p-8 border border-slate-200">
          <div class="w-10 h-10 bg-brand-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"
              ></path>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Acceso por carretera</h3>
          <p class="text-slate-600 font-light text-sm leading-relaxed">
            A-2 · M-22 · M-40 · M-11 · A 10 minutos del centro de Madrid
          </p>
        </div>
        <div class="scroll-reveal-item bg-white p-8 border border-slate-200">
          <div class="w-10 h-10 bg-brand-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
              ></path>
            </svg>
          </div>
          <h3 class="font-semibold text-slate-900 mb-2">Entorno y ocio</h3>
          <p class="text-slate-600 font-light text-sm leading-relaxed">
            Parque Juan Carlos I · Parque El Capricho · Club Golf Olivar de la Hinojosa · Polideportivo Municipal
            Barajas
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ EQUIPAMIENTOS ══ -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="scroll-reveal text-center mb-16">
        <div class="inline-block mb-4">
          <div class="h-px w-12 bg-slate-600 inline-block"></div>
          <span class="mx-4 text-slate-500 uppercase tracking-[0.3em] text-xs font-light">La Vivienda</span>
          <div class="h-px w-12 bg-slate-600 inline-block"></div>
        </div>
        <h2 class="text-4xl md:text-5xl font-serif font-bold text-slate-900">Características</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {
          urbanizacionItems.map((item) => (
            <div class="scroll-reveal-item bg-slate-50 border border-slate-100 p-5 flex flex-col gap-3 hover:border-slate-200 hover:shadow-sm transition-all duration-200">
              <div class="w-9 h-9 bg-brand-50 flex items-center justify-center text-brand-600 shrink-0">
                <Fragment set:html={item.icon} />
              </div>
              <div>
                <div class="font-semibold text-slate-900 text-sm leading-snug">{item.title}</div>
                <div class="text-slate-500 text-xs font-light mt-1 leading-relaxed">{item.desc}</div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════════════ CTA ══ -->
  <section class="py-24 bg-brand-600">
    <div class="scroll-reveal max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-4xl md:text-5xl font-serif font-bold text-white mb-6">¿Le interesa una promoción similar?</h2>
      <p class="text-white/80 font-light text-lg mb-10 leading-relaxed">
        Consulte nuestras promociones activas o póngase en contacto con nosotros para que le informemos sobre futuras
        promociones en Madrid.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/#promociones"
          class="inline-flex items-center justify-center gap-2 bg-white text-brand-600 font-semibold px-8 py-4 hover:bg-slate-50 transition-colors"
        >
          Ver otras promociones
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center justify-center gap-2 border border-white/40 text-white font-medium px-8 py-4 hover:border-white/70 hover:bg-white/10 transition-colors"
        >
          Recibir información
        </a>
      </div>
    </div>
  </section>

  <ContactoSection />
</PageLayout>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -80px 0px',
  };

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.scroll-reveal').forEach((el) => {
    revealObserver.observe(el);
  });

  const itemObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const siblings = entry.target.parentElement?.querySelectorAll('.scroll-reveal-item');
        const idx = siblings ? Array.from(siblings).indexOf(entry.target as Element) : 0;
        setTimeout(() => {
          entry.target.classList.add('is-visible');
        }, idx * 80);
        itemObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.scroll-reveal-item').forEach((el) => {
    itemObserver.observe(el);
  });
</script>

<style>
  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-fade {
    opacity: 0;
    animation: heroFadeIn 0.9s ease-out forwards;
  }

  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-reveal-item {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .scroll-reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade,
    .scroll-reveal,
    .scroll-reveal-item {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
      transition: none !important;
    }
  }
</style>
