---
import PageLayout from '~/layouts/PageLayout.astro';
import HeroSection from '~/components/landing/HeroSection.astro';
import StatsSection from '~/components/landing/StatsSection.astro';
import PromocionesSection from '~/components/landing/PromocionesSection.astro';
import CalidadSection from '~/components/landing/CalidadSection.astro';
import SobreNosotrosSection from '~/components/landing/SobreNosotrosSection.astro';
import PersonalizaSection from '~/components/landing/PersonalizaSection.astro';
import MisionSection from '~/components/landing/MisionSection.astro';
import ContactoSection from '~/components/landing/ContactoSection.astro';
import NewsletterCTA from '~/components/landing/NewsletterCTA.astro';
---

<PageLayout
  metadata={{
    title: 'Clement',
    description: 'Tu vivienda en Madrid',
  }}
>
  <HeroSection />
  <StatsSection />
  <PromocionesSection />
  <PersonalizaSection />
  <CalidadSection />
  <SobreNosotrosSection />
  <MisionSection />
  <ContactoSection />
  <NewsletterCTA />
</PageLayout>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -80px 0px',
  };

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.scroll-reveal').forEach((el) => {
    revealObserver.observe(el);
  });

  // Sibling-based stagger: each item's position in its parent determines its delay
  const itemObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const siblings = entry.target.parentElement?.querySelectorAll('.scroll-reveal-item');
        const idx = siblings ? Array.from(siblings).indexOf(entry.target as Element) : 0;
        setTimeout(() => {
          entry.target.classList.add('is-visible');
        }, idx * 80);
        itemObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.scroll-reveal-item').forEach((el) => {
    itemObserver.observe(el);
  });

  // Scale-in animation for full-bleed images
  const imgObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          imgObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px' }
  );

  document.querySelectorAll('.scroll-reveal-img').forEach((el) => {
    imgObserver.observe(el);
  });
</script>

<style is:global>
  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-fade {
    opacity: 0;
    animation: heroFadeIn 0.9s ease-out forwards;
  }

  /* Scroll reveal animations */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-reveal-item {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .scroll-reveal-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .scroll-reveal-img {
    opacity: 0;
    transform: scale(1.04);
    transition:
      opacity 1s ease-out,
      transform 1.2s ease-out;
  }

  .scroll-reveal-img.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  /* Smooth scrolling */
  html {
    scroll-behavior: smooth;
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .hero-fade,
    .scroll-reveal,
    .scroll-reveal-item,
    .scroll-reveal-img {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
      transition: none !important;
    }
  }
</style>
