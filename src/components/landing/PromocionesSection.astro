---
import imgPuertaHierro from '~/assets/images/landing/promocion-puerta-hierro.webp';
import imgAlamedaOsunaV from '~/assets/images/landing/promocion-alameda-osuna-v.jpg';
import imgAlamedaOsunaIV from '~/assets/images/landing/promocion-alameda-osuna-iv.jpg';
import imgAlamedaOsunaIII from '~/assets/images/landing/promocion-alameda-osuna-iii.jpg';
import imgAlamedaOsunaII from '~/assets/images/landing/promocion-alameda-osuna-ii.jpg';
import imgAlamedaOsunaI from '~/assets/images/landing/promocion-alameda-osuna-i.jpg';
---

<section id="promociones" class="py-32 bg-gradient-to-b from-slate-50 via-white to-slate-50 scroll-reveal">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20 scroll-reveal-item">
      <div class="inline-block mb-4">
        <div class="h-px w-12 bg-slate-600 inline-block"></div>
        <span class="mx-4 text-slate-500 uppercase tracking-[0.3em] text-xs font-light">Portfolio</span>
        <div class="h-px w-12 bg-slate-600 inline-block"></div>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-slate-900 mb-6">Nuestras Promociones</h2>
      <p class="text-slate-600 text-lg font-light max-w-2xl mx-auto">
        Excelencia arquitectónica en las mejores ubicaciones de Madrid
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Chalets Puerta de Hierro -->
      <div
        class="group bg-white overflow-hidden transition-all duration-700 border border-slate-200 hover:border-brand-500/50 scroll-reveal-item relative"
      >
        <div class="aspect-[4/3] relative overflow-hidden">
          <img
            src={imgPuertaHierro.src}
            alt="Chalets Puerta de Hierro"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>
          <span
            class="absolute top-6 right-6 bg-gradient-to-r from-emerald-600 to-emerald-700 text-white px-5 py-2 text-xs font-light uppercase tracking-wider backdrop-blur-sm border border-white/20"
            >Disponible</span
          >
        </div>
        <div class="p-8 bg-white group-hover:bg-slate-50/50 transition-colors duration-700">
          <div class="mb-4">
            <div class="h-px w-12 bg-brand-600 mb-4"></div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3 group-hover:text-slate-700 transition-colors">
              Chalets Puerta de Hierro
            </h3>
          </div>
          <p class="text-slate-600 leading-relaxed font-light">
            CLEMENT Puerta de Hierro es una promoción de 6 chalets pareados Gran Lujo en parcela de 500 m² aprox. con
            piscina individual y garaje privado. Viviendas de más de 400 m² construidos en un entorno exclusivo con
            seguridad 24 horas.
          </p>
        </div>
      </div>

      <!-- Alameda de Osuna V -->
      <div
        class="group bg-white overflow-hidden transition-all duration-700 border border-slate-200 hover:border-slate-300 scroll-reveal-item relative opacity-90"
      >
        <div class="aspect-[4/3] relative overflow-hidden">
          <img
            src={imgAlamedaOsunaV.src}
            alt="Alameda de Osuna V"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>
          <span
            class="absolute top-6 right-6 bg-slate-700/80 text-slate-200 px-5 py-2 text-xs font-light uppercase tracking-wider backdrop-blur-sm border border-white/10"
            >Entregado</span
          >
        </div>
        <div class="p-8 bg-slate-50/30">
          <div class="mb-4">
            <div class="h-px w-12 bg-slate-300 mb-4"></div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3">Alameda de Osuna V</h3>
          </div>
          <p class="text-slate-600 leading-relaxed font-light">
            CLEMENT Alameda de Osuna V se distribuye en dos portales de cinco plantas más ático en cada uno de ellos. La
            promoción está compuesta por 48 viviendas de 2 y 4 dormitorios con terraza, plaza de garaje, piscina y zonas
            comunes.
          </p>
        </div>
      </div>

      <!-- Alameda de Osuna IV -->
      <div
        class="group bg-white overflow-hidden transition-all duration-700 border border-slate-200 hover:border-slate-300 scroll-reveal-item relative opacity-90"
      >
        <div class="aspect-[4/3] relative overflow-hidden">
          <img
            src={imgAlamedaOsunaIV.src}
            alt="Alameda de Osuna IV"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>
          <span
            class="absolute top-6 right-6 bg-slate-700/80 text-slate-200 px-5 py-2 text-xs font-light uppercase tracking-wider backdrop-blur-sm border border-white/10"
            >Entregado</span
          >
        </div>
        <div class="p-8 bg-slate-50/30">
          <div class="mb-4">
            <div class="h-px w-12 bg-slate-300 mb-4"></div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3">Alameda de Osuna IV</h3>
          </div>
          <p class="text-slate-600 leading-relaxed font-light">
            CLEMENT Alameda de Osuna IV se distribuye en cuatro portales con cuatro plantas más ático en cada uno de
            ellos. La promoción está formada por 43 viviendas de 2, 3 y 4 dormitorios, todas ellas con terraza, trastero
            y garaje.
          </p>
        </div>
      </div>

      <!-- Alameda de Osuna III -->
      <div
        class="group bg-white overflow-hidden transition-all duration-700 border border-slate-200 hover:border-slate-300 scroll-reveal-item relative opacity-90"
      >
        <div class="aspect-[4/3] relative overflow-hidden">
          <img
            src={imgAlamedaOsunaIII.src}
            alt="Alameda de Osuna III"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>
          <span
            class="absolute top-6 right-6 bg-slate-700/80 text-slate-200 px-5 py-2 text-xs font-light uppercase tracking-wider backdrop-blur-sm border border-white/10"
            >Entregado</span
          >
        </div>
        <div class="p-8 bg-slate-50/30">
          <div class="mb-4">
            <div class="h-px w-12 bg-slate-300 mb-4"></div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3">Alameda de Osuna III</h3>
          </div>
          <p class="text-slate-600 leading-relaxed font-light">
            CLEMENT pone a la venta esta excelente Promoción de 66 viviendas, pisos de 1, 2, 3 y 4 dormitorios
            distribuidos en 5 portales: 1ª, 2ª, 3ª y 4ª planta y áticos. Todas las viviendas disponen de terraza.
          </p>
        </div>
      </div>

      <!-- Alameda de Osuna II -->
      <div
        class="group bg-white overflow-hidden transition-all duration-700 border border-slate-200 hover:border-slate-300 scroll-reveal-item relative opacity-90"
      >
        <div class="aspect-[4/3] relative overflow-hidden">
          <img
            src={imgAlamedaOsunaII.src}
            alt="Alameda de Osuna II"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>
          <span
            class="absolute top-6 right-6 bg-slate-700/80 text-slate-200 px-5 py-2 text-xs font-light uppercase tracking-wider backdrop-blur-sm border border-white/10"
            >Entregado</span
          >
        </div>
        <div class="p-8 bg-slate-50/30">
          <div class="mb-4">
            <div class="h-px w-12 bg-slate-300 mb-4"></div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3">Alameda de Osuna II</h3>
          </div>
          <p class="text-slate-600 leading-relaxed font-light">
            CLEMENT Alameda de Osuna II se distribuye en cuatro portales con cuatro plantas más ático en cada uno de
            ellos. La promoción está formada por 43 viviendas de 2, 3 y 4 dormitorios, todas ellas con terraza, trastero
            y garaje.
          </p>
        </div>
      </div>

      <!-- Alameda de Osuna I -->
      <div
        class="group bg-white overflow-hidden transition-all duration-700 border border-slate-200 hover:border-slate-300 scroll-reveal-item relative opacity-90"
      >
        <div class="aspect-[4/3] relative overflow-hidden">
          <img
            src={imgAlamedaOsunaI.src}
            alt="Alameda de Osuna I"
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-slate-900/10 to-transparent"></div>
          <span
            class="absolute top-6 right-6 bg-slate-700/80 text-slate-200 px-5 py-2 text-xs font-light uppercase tracking-wider backdrop-blur-sm border border-white/10"
            >Entregado</span
          >
        </div>
        <div class="p-8 bg-slate-50/30">
          <div class="mb-4">
            <div class="h-px w-12 bg-slate-300 mb-4"></div>
            <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3">Alameda de Osuna I</h3>
          </div>
          <p class="text-slate-600 leading-relaxed font-light">
            CLEMENT Alameda de Osuna I se distribuye en cinco portales con cuatro plantas más ático en cada uno de
            ellos. La promoción está formada por 44 viviendas de 1, 2, 3 y 4 dormitorios, todas ellas con terraza,
            trastero y garaje.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
