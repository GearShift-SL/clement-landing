---

---

<section id="contacto" class="py-32 bg-linear-to-b from-slate-50 to-white scroll-reveal">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-20 scroll-reveal-item">
      <div class="inline-block mb-6">
        <div class="h-px w-12 bg-slate-800 inline-block"></div>
        <span class="mx-4 text-slate-800 uppercase tracking-[0.3em] text-xs font-light">Hablemos</span>
        <div class="h-px w-12 bg-slate-800 inline-block"></div>
      </div>
      <h2 class="text-5xl md:text-6xl font-serif font-bold text-slate-900 mb-6">Contacte con Nosotros</h2>
      <p class="text-slate-600 text-lg font-light max-w-2xl mx-auto">Estamos aquí para resolver cualquier duda.</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12">
      <!-- Map & Address -->
      <div class="scroll-reveal-item">
        <div class="bg-white p-10 shadow-2xl h-full border border-slate-200">
          <div class="mb-8">
            <div class="h-px w-16 bg-slate-600 mb-4"></div>
            <h3 class="text-3xl font-serif font-bold text-slate-900 mb-6">Venga a Vernos</h3>
            <p class="text-slate-700 leading-relaxed font-light text-lg">
              En nuestras oficinas de <span class="font-bold">Santibáñez de Béjar, 6, Madrid</span> estaremos encantados de
              atenderle e informarle acerca de nuestras promociones de viviendas en venta e inmuebles disponibles en arrendamiento.
              Nuestro equipo comercial está siempre a su disposición.
            </p>
          </div>

          <!-- Google Maps Embed -->
          <div class="aspect-video overflow-hidden shadow-lg border border-slate-200 mb-6">
            <iframe
              class="w-full h-full"
              frameborder="0"
              scrolling="no"
              marginheight="0"
              marginwidth="0"
              id="gmap_canvas"
              src="https://maps.google.com/maps?width=100%&height=100%&hl=en&q=clement santibañez de bejar 6&t=&z=14&ie=UTF8&iwloc=B&output=embed"
            ></iframe>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mt-6">
            <a
              href="mailto:info@clement.es"
              class="flex-1 flex items-center justify-center gap-3 bg-linear-to-r from-slate-900 to-slate-800 text-white font-light uppercase tracking-wider py-4 px-6 hover:from-brand-700 hover:to-brand-800 transition-all duration-500 shadow-lg hover:shadow-2xl border border-slate-900 hover:border-brand-700"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
              info@clement.es
            </a>
            <a
              href="tel:+34917472917"
              class="flex-1 flex items-center justify-center gap-3 bg-white text-slate-900 font-light uppercase tracking-wider py-4 px-6 hover:bg-slate-50 transition-all duration-500 shadow-lg hover:shadow-2xl border-2 border-slate-900 hover:border-slate-600 hover:text-slate-600"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                ></path>
              </svg>
              91 747 29 17
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="scroll-reveal-item">
        <form
          id="contact-form"
          class="bg-white p-10 shadow-2xl border border-slate-200 h-full"
          style="transition: opacity 0.5s ease, transform 0.5s ease;"
        >
          <div class="space-y-6">
            <div>
              <label for="name" class="block text-xs font-light uppercase tracking-wider text-slate-600 mb-3"
                >Nombre completo <span class="text-red-500">*</span></label
              >
              <input
                type="text"
                id="name"
                name="name"
                class="w-full px-5 py-4 border border-slate-300 focus:border-brand-600 focus:outline-none focus:ring-1 focus:ring-brand-600 transition-all bg-slate-50 focus:bg-white font-light"
                placeholder="Tu nombre"
                required
              />
            </div>

            <div>
              <label for="phone" class="block text-xs font-light uppercase tracking-wider text-slate-600 mb-3"
                >Teléfono</label
              >
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-5 py-4 border border-slate-300 focus:border-brand-600 focus:outline-none focus:ring-1 focus:ring-brand-600 transition-all bg-slate-50 focus:bg-white font-light"
                placeholder="+34 600 000 000"
              />
            </div>

            <div>
              <label for="email" class="block text-xs font-light uppercase tracking-wider text-slate-600 mb-3"
                >Email <span class="text-red-500">*</span></label
              >
              <input
                type="email"
                id="email"
                name="email"
                class="w-full px-5 py-4 border border-slate-300 focus:border-brand-600 focus:outline-none focus:ring-1 focus:ring-brand-600 transition-all bg-slate-50 focus:bg-white font-light"
                placeholder="tu@email.com"
                required
              />
            </div>

            <div>
              <label for="message" class="block text-xs font-light uppercase tracking-wider text-slate-600 mb-3"
                >Mensaje</label
              >
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full px-5 py-4 border border-slate-300 focus:border-brand-600 focus:outline-none focus:ring-1 focus:ring-brand-600 transition-all bg-slate-50 focus:bg-white resize-none font-light"
                placeholder="Cuéntanos en qué podemos ayudarte..."></textarea>
            </div>

            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 h-4 w-4 shrink-0 border-slate-300 text-brand-600 focus:ring-brand-600 accent-slate-800"
              />
              <label for="privacy" class="text-sm text-slate-600 font-light leading-relaxed">
                He leído y acepto la <a
                  href="/privacy"
                  class="underline text-slate-900 hover:text-brand-700 transition-colors">política de privacidad</a
                >
                <span class="text-red-500">*</span>
              </label>
            </div>

            <p id="contact-feedback" class="text-sm text-center hidden"></p>

            <button
              id="contact-submit"
              type="submit"
              class="w-full bg-linear-to-r hover:cursor-pointer from-slate-900 to-slate-800 text-white font-light uppercase tracking-wider py-5 px-6 hover:from-brand-700 hover:to-brand-800 transition-all duration-500 shadow-lg hover:shadow-2xl border border-slate-900 hover:border-brand-700"
            >
              Enviar mensaje
            </button>
          </div>
        </form>

        <div
          id="contact-success"
          class="hidden flex-col items-center justify-center bg-white p-10 shadow-2xl border border-slate-200 h-full text-center opacity-0 transition-all duration-500"
          style="transform: scale(0.95) translateY(10px);"
        >
          <svg class="w-16 h-16 text-green-500 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h3 class="text-2xl font-serif font-bold text-slate-900 mb-3">¡Mensaje enviado!</h3>
          <p class="text-slate-600 font-light">Gracias por contactarnos. Le responderemos lo antes posible.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement;
  const feedback = document.getElementById('contact-feedback') as HTMLParagraphElement;
  const successPanel = document.getElementById('contact-success') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const formData = new FormData(form);

    if (!formData.get('privacy')) {
      feedback.textContent = 'Debe aceptar la política de privacidad.';
      feedback.className = 'text-sm text-center text-red-400';
      return;
    }

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Enviando...';
    feedback.className = 'text-sm text-center hidden';

    const payload = {
      audience: {
        name: 'clement_contacto',
        audience_type: 'contact_form',
      },
      email: formData.get('email'),
      first_name: formData.get('name'),
      phone: formData.get('phone'),
      message: formData.get('message'),
      source: 1,
    };

    try {
      const response = await fetch('https://formrelay.hlab.es/api/subscribers/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error('Error en el envío');

      form.style.opacity = '0';
      form.style.transform = 'scale(0.95) translateY(-10px)';

      setTimeout(() => {
        form.style.display = 'none';

        successPanel.classList.remove('hidden');
        successPanel.style.display = 'flex';
        void successPanel.offsetWidth;
        successPanel.style.opacity = '1';
        successPanel.style.transform = 'scale(1) translateY(0)';
      }, 500);
    } catch {
      feedback.textContent = 'Ha ocurrido un error. Por favor, inténtelo de nuevo más tarde.';
      feedback.className = 'text-sm text-center text-red-400';
      submitBtn.disabled = false;
      submitBtn.textContent = originalText;
    }
  });
</script>
