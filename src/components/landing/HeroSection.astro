---
import Logo from '~/assets/icons/logo.svg';
import heroVideo from '~/assets/videos/hero.mp4';
---

<section id="top" class="relative w-full h-screen overflow-hidden flex items-center justify-center">
  <video
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 min-w-full min-h-full w-auto h-full object-cover -z-20"
    autoplay
    muted
    loop
    playsinline
  >
    <source src={heroVideo} type="video/mp4" />
  </video>

  <div class="absolute inset-0 bg-linear-to-b from-black/10 via-black/30 to-black/50 -z-10"></div>

  <div class="flex flex-col items-center justify-center text-center p-8 z-10">
    <Logo class="hero-fade w-[min(400px,80vw)] h-auto text-white mb-12" style="animation-delay: 0.1s" />

    <p
      class="hero-fade font-serif text-2xl md:text-3xl text-white/90 font-light tracking-wide max-w-[600px] leading-relaxed italic"
      style="animation-delay: 0.3s"
    >
      Referentes en la promoción y construcción de viviendas desde 1972
    </p>

    <a
      href="#stats"
      class="hero-fade mt-20 flex flex-col items-center text-white/60 hover:text-white transition-colors group"
      style="animation-delay: 0.5s"
    >
      <span class="text-xs tracking-[0.25em] uppercase mb-3">Descubre</span>
      <svg class="w-5 h-5 animate-bounce" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
      </svg>
    </a>
  </div>
</section>
