---
interface Props {
  tag?: string;
}

const { tag = 'futuras-promociones' } = Astro.props;
---

<div id="newsletter" class="mb-16 scroll-reveal-item scroll-mt-60" data-tag={tag}>
  <div class="bg-slate-900 px-10 py-10 flex flex-col gap-6">
    <div class="flex flex-col md:flex-row items-center gap-8">
      <div class="flex-1 text-center md:text-left">
        <p class="text-slate-400 text-xs uppercase tracking-[0.3em] font-light mb-2">Avant-première</p>
        <h3 class="text-2xl font-serif font-bold text-white">Reciba noticias de futuras promociones</h3>
        <p class="text-slate-400 font-light mt-2 text-sm">
          Sea el primero en conocer nuestros nuevos proyectos y oportunidades exclusivas.
        </p>
      </div>
      <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 w-full md:w-auto md:min-w-[420px]">
        <input
          type="email"
          id="newsletter-email"
          name="email"
          required
          placeholder="tu@email.com"
          class="flex-1 px-5 py-4 bg-slate-800 border border-slate-700 text-white placeholder-slate-500 focus:border-brand-500 focus:outline-none focus:ring-1 focus:ring-brand-500 transition-all font-light"
        />
        <button
          id="newsletter-submit"
          type="submit"
          class="px-8 py-4 hover:cursor-pointer bg-brand-600 hover:bg-brand-700 text-white font-light uppercase tracking-wider transition-all duration-300 border border-brand-600 hover:border-brand-700 whitespace-nowrap"
        >
          Suscribirme
        </button>
      </form>
      <p id="newsletter-feedback" class="hidden text-sm text-center md:text-left"></p>
    </div>
    <p class="text-slate-500 text-xs font-light text-center">
      Al suscribirse, acepta nuestra <a href="/politica-de-privacidad" class="underline hover:text-slate-300 transition-colors">política de privacidad</a> y consiente recibir comunicaciones comerciales de Clement.
    </p>
  </div>
  <div id="newsletter-success" class="hidden bg-slate-900 px-10 py-10 flex items-center justify-center gap-4">
    <svg class="w-8 h-8 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <p class="text-white font-light text-lg">¡Gracias! Te avisaremos cuando lancemos nuevas promociones.</p>
  </div>
</div>

<script>
  const wrapper = document.querySelector('[data-tag]') as HTMLElement;
  const tag = wrapper?.dataset.tag ?? 'futuras-promociones';

  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const submitBtn = document.getElementById('newsletter-submit') as HTMLButtonElement;
  const feedback = document.getElementById('newsletter-feedback') as HTMLParagraphElement;
  const successPanel = document.getElementById('newsletter-success') as HTMLDivElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = (document.getElementById('newsletter-email') as HTMLInputElement).value;

    submitBtn.disabled = true;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Enviando...';
    feedback.className = 'hidden text-sm';

    const payload = {
      audience: {
        name: 'clement_waitlist',
        audience_type: 'waitlist',
      },
      email,
      source: 1,
      custom_data: { tags: [tag] },
    };

    try {
      const response = await fetch('https://formrelay.hlab.es/api/subscribers/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) throw new Error('Error en el envío');

      form.style.display = 'none';
      successPanel.classList.remove('hidden');
      successPanel.style.display = 'flex';
    } catch {
      feedback.textContent = 'Ha ocurrido un error. Por favor, inténtelo de nuevo más tarde.';
      feedback.className = 'text-sm text-red-400';
      submitBtn.disabled = false;
      submitBtn.textContent = originalText ?? 'Suscribirme';
    }
  });
</script>
