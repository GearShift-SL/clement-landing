---
---

<div
  id="newsletter-cta-bar"
  class="fixed bottom-6 left-0 right-0 z-50 flex justify-center px-4 transition-all duration-500"
  style="transform: translateY(0); opacity: 1;"
>
  <div class="relative">
    <span class="ripple ripple-1"></span>
    <span class="ripple ripple-2"></span>
    <span class="ripple ripple-3"></span>
    <a
      href="#newsletter"
      class="relative inline-flex items-center gap-2.5 bg-slate-900/95 backdrop-blur-sm text-white text-sm font-light uppercase tracking-wider px-6 py-3.5 shadow-2xl border border-slate-700 hover:bg-brand-700 hover:border-brand-600 transition-all duration-300 whitespace-nowrap"
    >
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
        ></path>
      </svg>
      Recibir noticias de promociones
    </a>
  </div>
</div>

<style>
  .ripple {
    position: absolute;
    inset: 0;
    border: 2px solid rgb(148 163 184 / 0.7);
    animation: ripple-out 4s ease-out infinite;
    pointer-events: none;
  }
  .ripple-2 { animation-delay: 1.33s; }
  .ripple-3 { animation-delay: 2.66s; }

  @keyframes ripple-out {
    0%   { transform: scale(1);   opacity: 0.8; }
    100% { transform: scale(1.9); opacity: 0; }
  }
</style>

<script>
  const bar = document.getElementById('newsletter-cta-bar') as HTMLElement;
  const newsletterEl = document.getElementById('newsletter');

  if (!newsletterEl) {
    bar?.remove();
  } else {
    const hide = () => {
      bar.style.opacity = '0';
      bar.style.transform = 'translateY(20px)';
      bar.style.pointerEvents = 'none';
    };
    const show = () => {
      bar.style.opacity = '1';
      bar.style.transform = 'translateY(0)';
      bar.style.pointerEvents = '';
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            hide();
          } else {
            // Only show if success panel is not visible (not yet subscribed)
            const success = document.getElementById('newsletter-success');
            if (!success || success.style.display === 'none' || success.classList.contains('hidden')) {
              show();
            }
          }
        });
      },
      { threshold: 0.1 }
    );

    observer.observe(newsletterEl);

    // Also hide permanently after successful subscription
    const successEl = document.getElementById('newsletter-success');
    if (successEl) {
      new MutationObserver(() => {
        if (successEl.style.display === 'flex') hide();
      }).observe(successEl, { attributes: true, attributeFilter: ['style'] });
    }
  }
</script>
